# KUKAN — Production Overrides
# Copy to .env.prod and set your values:
#   cp .env.prod.example .env.prod
#
# Start:
#   docker compose --env-file .env --env-file .env.prod --profile prod up -d

# Public URL where KUKAN is accessible (auth callbacks, CORS)
# e.g. http://192.168.1.100, https://catalog.example.com
BETTER_AUTH_URL=http://localhost

# Auth secret (generate: openssl rand -base64 32)
# BETTER_AUTH_SECRET=

# Registration (set to false to disable self-registration)
# REGISTRATION_ENABLED=true

# --- Docker internal endpoints (override .env localhost values) ---
S3_ENDPOINT=http://minio:9000
OPENSEARCH_URL=http://opensearch:9200
SQS_ENDPOINT=http://elasticmq:9324
SQS_QUEUE_URL=http://elasticmq:9324/000000000000/kukan-pipeline

# --- Override as needed ---
# POSTGRES_HOST=postgres
# POSTGRES_DB=kukan
# POSTGRES_USER=kukan
# POSTGRES_PASSWORD=kukan
# POSTGRES_SSLMODE=require
# S3_BUCKET=kukan-dev
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# SEARCH_TYPE=opensearch
# OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m
# SQS_ACCESS_KEY=x
# SQS_SECRET_KEY=x
# HTTP_PORT=80
# HTTPS_PORT=443
