{
  "name": "@kukan/shared",
  "version": "0.1.0",
  "private": true,
  "description": "KUKAN shared types, validators, utilities",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "encoding-japanese": "^2.2.0",
    "lru-cache": "^11.0.0",
    "zod": "3.25.67"
  },
  "devDependencies": {
    "@types/encoding-japanese": "^2.2.1",
    "@types/node": "^22.0.0"
  }
}
