{
  "name": "@kukan/db",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "description": "KUKAN database schema and migrations (Drizzle ORM)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@kukan/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@types/pg": "^8.20.0",
    "dotenv": "^16.6.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0"
  }
}
