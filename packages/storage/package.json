{
  "name": "@kukan/storage",
  "version": "0.1.0",
  "private": true,
  "description": "KUKAN storage adapter (S3/MinIO/Local)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@kukan/shared": "workspace:*",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "minio": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0"
  }
}
