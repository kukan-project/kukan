{
  "name": "@kukan/search-adapter",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "description": "KUKAN search adapter (OpenSearch/PostgreSQL)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@kukan/db": "workspace:*",
    "@kukan/shared": "workspace:*",
    "@opensearch-project/opensearch": "^3.5.1",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@types/node": "^22.19.15"
  }
}
