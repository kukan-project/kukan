{
  "name": "@kukan/storage-adapter",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "description": "KUKAN storage adapter (S3-compatible/Local)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1027.0",
    "@aws-sdk/lib-storage": "^3.1027.0",
    "@aws-sdk/s3-request-presigner": "^3.1027.0",
    "@kukan/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.19.15"
  }
}
