{
  "name": "@kukan/worker",
  "version": "0.1.0",
  "private": true,
  "description": "KUKAN Worker — SQS queue consumer for resource pipeline",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
