# KUKAN Environment Variables
# Copy this file to .env and adjust values for your environment

# Node.js Environment
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://kukan:kukan@localhost:5432/kukan

# Storage (S3-compatible: works with both AWS S3 and MinIO)
# For development with MinIO:
STORAGE_TYPE=s3
S3_BUCKET=kukan-dev
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# For production AWS S3 (omit S3_ENDPOINT to use default AWS endpoint, use IAM role):
# STORAGE_TYPE=s3
# S3_BUCKET=your-bucket-name
# S3_REGION=ap-northeast-1

# For local filesystem storage (no S3/MinIO required):
# STORAGE_TYPE=local

# Search (postgres for fallback, opensearch for full-text)
SEARCH_TYPE=postgres

# For development with OpenSearch (run: docker compose --profile search up):
# SEARCH_TYPE=opensearch
# OPENSEARCH_URL=http://localhost:9200

# For production AWS OpenSearch:
# SEARCH_TYPE=opensearch
# OPENSEARCH_URL=https://your-opensearch-endpoint

# Queue (in-process for Phase 1, sqs for Phase 3+)
QUEUE_TYPE=in-process

# For production SQS deployment (Phase 3):
# QUEUE_TYPE=sqs
# SQS_QUEUE_URL=https://sqs.region.amazonaws.com/account/queue

# AI (none for Phase 1-4, bedrock/openai/ollama for Phase 5+)
AI_TYPE=none

# For production AI deployment (Phase 5):
# AI_TYPE=bedrock
# AWS_BEDROCK_REGION=us-east-1

# Authentication (Better Auth)
# Generate a secure random string: openssl rand -base64 32
BETTER_AUTH_SECRET=change-this-to-at-least-32-characters-secret-key
BETTER_AUTH_URL=http://localhost:3000

# Trusted Origins (comma-separated, for CORS in standalone API mode)
# TRUSTED_ORIGINS=http://localhost:3000
