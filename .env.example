# KUKAN Environment Variables
# Copy this file to .env and adjust values for your environment

# Node.js Environment
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://kukan:kukan@localhost:5432/kukan

# DB Connection Pool — Web (API): defaults max=5, idle=30s, connect=3s
# DB_POOL_MAX=5
# DB_POOL_IDLE_TIMEOUT_MS=30000
# DB_POOL_CONNECTION_TIMEOUT_MS=3000

# DB Connection Pool — Worker: defaults max=3, idle=10s, connect=30s
# WORKER_DB_POOL_MAX=3
# WORKER_DB_POOL_IDLE_TIMEOUT_MS=10000
# WORKER_DB_POOL_CONNECTION_TIMEOUT_MS=30000

# Storage (S3-compatible: AWS S3 or MinIO, determined by S3_ENDPOINT)
# Omit S3_ENDPOINT to use default AWS endpoint (use IAM role)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=kukan-dev
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Search (opensearch recommended; postgres fallback for cost savings)
SEARCH_TYPE=opensearch
OPENSEARCH_URL=http://localhost:9200

# Queue (SQS-compatible: AWS SQS or ElasticMQ, determined by SQS_ENDPOINT)
# Omit SQS_ENDPOINT and SET SQS_REGION to use default AWS endpoint (use IAM role)
# SQS_REGION=ap-northeast-1
SQS_ENDPOINT=http://localhost:9324
SQS_QUEUE_URL=http://localhost:9324/000000000000/kukan-pipeline
SQS_ACCESS_KEY=x
SQS_SECRET_KEY=x

# AI (none for Phase 1-4, bedrock/openai/ollama for Phase 5+)
AI_TYPE=none

# For production AI deployment (Phase 5):
# AI_TYPE=bedrock
# AWS_BEDROCK_REGION=us-east-1

# Authentication (Better Auth)
# Generate a secure random string: openssl rand -base64 32
BETTER_AUTH_SECRET=change-this-to-at-least-32-characters-secret-key
BETTER_AUTH_URL=http://localhost:3000

# Trusted Origins (comma-separated, for CORS in standalone API mode)
# TRUSTED_ORIGINS=http://localhost:3000
