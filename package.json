{
  "name": "kukan",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/kukan-project/kukan.git"
  },
  "bugs": {
    "url": "https://github.com/kukan-project/kukan/issues"
  },
  "homepage": "https://github.com/kukan-project/kukan#readme",
  "type": "module",
  "description": "Knowledge Unified Katalog And Network - Modern CKAN alternative",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "vitest run",
    "test:unit": "vitest run --exclude '**/*.integration.test.ts'",
    "test:integration": "vitest run --include '**/*.integration.test.ts'",
    "test:watch": "vitest",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "turbo": "^2.9.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "vitest": "^2.1.9"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  }
}
